VERSION 0.7
PROJECT example/rust-app

ARG RUST_VERSION=1.75
ARG REGISTRY=docker.io

FROM rust:${RUST_VERSION}
WORKDIR /work
ENV CARGO_HOME=/work/.cargo

deps:
    COPY Cargo.toml Cargo.lock ./
    RUN mkdir src && echo "fn main() {}" > src/main.rs
    RUN cargo build --release
    SAVE ARTIFACT target/release/deps

source:
    FROM +deps
    COPY src ./src
    COPY tests ./tests

lint:
    FROM +source
    RUN cargo fmt --check
    RUN cargo clippy --all-targets -- -D warnings

test:
    FROM +source
    RUN cargo test --workspace --release

build:
    FROM +source
    RUN cargo build --release --workspace
    SAVE ARTIFACT target/release/app /app

image:
    FROM debian:bookworm-slim
    WORKDIR /app
    COPY +build/app /app/
    EXPOSE 8080
    ENTRYPOINT ["/app/app"]
    CMD ["--config", "/etc/app/config.toml"]
    SAVE IMAGE ${REGISTRY}/example/app:latest

ci:
    BUILD +lint
    BUILD +test
    BUILD +image

publish:
    FROM +source
    RUN --secret CARGO_REGISTRY_TOKEN cargo publish --token ${CARGO_REGISTRY_TOKEN}
